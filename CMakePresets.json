{
  "version": 6,
  "configurePresets": [
    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SWBT_BACKEND": "libusb",
        "SWBT_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "linux-asan",
      "displayName": "Linux ASan/UBSan",
      "inherits": "linux-debug",
      "binaryDir": "${sourceDir}/build/linux-asan",
      "cacheVariables": {
        "SWBT_ENABLE_ASAN": "ON",
        "SWBT_ENABLE_UBSAN": "ON"
      }
    },
    {
      "name": "linux-clang-tidy",
      "displayName": "Linux clang-tidy",
      "inherits": "linux-debug",
      "binaryDir": "${sourceDir}/build/linux-clang-tidy",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "SWBT_ENABLE_CLANG_TIDY": "ON"
      }
    },
    {
      "name": "windows-mingw-debug",
      "displayName": "Windows MinGW Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-mingw-debug",
      "toolchainFile": "${sourceDir}/cmake/toolchains/mingw-w64-x86_64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SWBT_BACKEND": "windows-winusb",
        "SWBT_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-mingw-release",
      "displayName": "Windows MinGW Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows-mingw-release",
      "toolchainFile": "${sourceDir}/cmake/toolchains/mingw-w64-x86_64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SWBT_BACKEND": "windows-winusb",
        "SWBT_BUILD_TESTS": "OFF",
        "SWBT_BUILD_SHARED": "OFF",
        "SWBT_VERSION_SUFFIX": ""
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug"
    },
    {
      "name": "linux-asan",
      "configurePreset": "linux-asan"
    },
    {
      "name": "linux-clang-tidy",
      "configurePreset": "linux-clang-tidy"
    },
    {
      "name": "windows-mingw-debug",
      "configurePreset": "windows-mingw-debug"
    },
    {
      "name": "windows-mingw-release",
      "configurePreset": "windows-mingw-release"
    }
  ],
  "testPresets": [
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-asan",
      "configurePreset": "linux-asan",
      "environment": {
        "ASAN_OPTIONS": "detect_leaks=0"
      },
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
