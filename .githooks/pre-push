#!/bin/sh
set -eu

if [ "${SWBT_SKIP_HOOKS:-0}" = "1" ]; then
    echo "[pre-push] SWBT_SKIP_HOOKS=1, skipping"
    exit 0
fi

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

if [ "${SWBT_FAST_PRE_PUSH:-0}" = "1" ]; then
    echo "[pre-push] just debug (SWBT_FAST_PRE_PUSH=1: build/test only)"
    just debug
else
    echo "[pre-push] just verify (format-check, clang-tidy, debug, ASan, Windows cross build)"
    just verify
fi
