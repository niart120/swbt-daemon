#!/bin/sh
set -eu

if [ "${SWBT_SKIP_HOOKS:-0}" = "1" ]; then
    echo "[pre-push] SWBT_SKIP_HOOKS=1, skipping"
    exit 0
fi

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

if [ "${SWBT_FULL_PRE_PUSH:-0}" = "1" ]; then
    echo "[pre-push] make verify"
    make verify
else
    echo "[pre-push] make debug"
    make debug
fi
