#!/bin/sh
set -eu

if [ "${SWBT_SKIP_HOOKS:-0}" = "1" ]; then
    echo "[commit-msg] SWBT_SKIP_HOOKS=1, skipping"
    exit 0
fi

msg_file=${1:?commit message file is required}
first_line=$(sed -n '1p' "$msg_file")

case "$first_line" in
    "Merge "*)
        exit 0
        ;;
esac

commit_pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([A-Za-z0-9._-]+\))?(!)?: [^ ].*'

if ! printf '%s\n' "$first_line" | grep -Eq "$commit_pattern"; then
    cat >&2 <<'EOF'
[commit-msg] Commit message must follow Conventional Commits:

  <type>(<scope>): <subject>
  <type>: <subject>

Allowed types:
  feat fix docs style refactor perf test build ci chore revert

Example:
  docs(readme): README を整理
EOF
    exit 1
fi

subject=${first_line#*: }
case "$subject" in
    *"." | *"。")
        echo "[commit-msg] Subject must not end with a period." >&2
        exit 1
        ;;
esac
